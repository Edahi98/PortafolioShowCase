---
import '../../styles/global.css';
import { Crown, FileText } from '@lucide/astro';
import Navbar from '../../components/Navbar.astro';
import { proyectos } from '../../data/proyectos';

export function getStaticPaths() {
	return proyectos
		.filter((proyecto) => proyecto.slug)
		.map((proyecto) => ({
			params: { slug: proyecto.slug },
			props: { proyecto },
		}));
}

const { proyecto } = Astro.props;

const relacionados = (proyecto.relacionados ?? [])
	.map((nombre: string) => proyectos.find((p) => p.nombre === nombre))
	.filter((p): p is (typeof proyectos)[number] => Boolean(p));
---
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{proyecto.nombre} · Edahi Yaxquin Avila Garcia</title>
		<meta name="description" content={proyecto.descripcion} />
	</head>
	<body class="min-h-screen text-slate-200 antialiased">
		<Navbar />
		<main class="mx-auto flex max-w-5xl flex-col gap-8 px-6 py-16 sm:px-8">
			<div class="flex flex-col gap-3">
				<a
					href="/#proyectos"
					class="w-fit font-mono text-xs tracking-widest text-primary uppercase transition hover:text-secondary"
				>
					&larr; Volver a Proyectos
				</a>
				<h1 class="flex items-center gap-3 text-2xl font-bold sm:text-4xl">
					<span class="text-gradient">{proyecto.nombre}</span>
					{proyecto.destacado && <Crown class="h-6 w-6 shrink-0 text-amber-400 sm:h-8 sm:w-8" aria-label="Proyecto destacado" />}
				</h1>
				<p class="max-w-2xl text-sm text-slate-400">{proyecto.descripcion}</p>
				<div class="flex flex-wrap items-center gap-2 pt-2">
					{proyecto.stack.map((tech: string) => (
						<span class="rounded-full border border-border bg-surface-2 px-3 py-1 font-mono text-xs text-primary">
							{tech}
						</span>
					))}
					{proyecto.repoUrl && (
						<a
							href={proyecto.repoUrl}
							target="_blank"
							rel="noreferrer"
							aria-label="Ver repositorio en GitHub"
							class="ml-1 transition hover:opacity-80"
						>
							<img
								src="https://skillicons.dev/icons?i=github"
								alt="Repositorio en GitHub"
								width={28}
								height={28}
								class="h-7 w-7"
							/>
						</a>
					)}
					{proyecto.dockerHubUrl && (
						<a
							href={proyecto.dockerHubUrl}
							target="_blank"
							rel="noreferrer"
							aria-label="Ver imagen en Docker Hub"
							class="transition hover:opacity-80"
						>
							<img
								src="https://skillicons.dev/icons?i=docker"
								alt="Imagen en Docker Hub"
								width={28}
								height={28}
								class="h-7 w-7"
							/>
						</a>
					)}
					{proyecto.documentacionUrl && (
						<a
							href={proyecto.documentacionUrl}
							target="_blank"
							rel="noreferrer"
							class="ml-1 inline-flex items-center gap-1.5 rounded-full border border-emerald-400/60 bg-emerald-400/15 px-3 py-1 font-mono text-xs font-semibold text-emerald-300 shadow-[0_0_12px_-2px] shadow-emerald-400/50 transition hover:bg-emerald-400/25"
						>
							<FileText class="h-3.5 w-3.5" aria-hidden="true" />
							Documentación
						</a>
					)}
				</div>
			</div>

			{
				proyecto.imagenes && proyecto.imagenes.length > 0 ? (
					<div class="flex flex-col gap-6">
						{proyecto.imagenes.map((imagen: { src: string; alt: string; descripcion: string }) => (
							<figure class="glass-card overflow-hidden rounded-2xl">
								<img src={imagen.src} alt={imagen.alt} loading="lazy" class="w-full" />
								<figcaption class="border-t border-border px-6 py-4 text-sm text-slate-400">
									{imagen.descripcion}
								</figcaption>
							</figure>
						))}
					</div>
				) : (
					<p class="font-mono text-xs text-slate-500">Capturas próximamente.</p>
				)
			}

			{
				relacionados.length > 0 && (
					<div class="flex flex-col gap-3 border-t border-border pt-8">
						<h2 class="text-sm font-mono tracking-widest text-secondary uppercase">Proyectos relacionados</h2>
						<div class="flex flex-wrap gap-2">
							{relacionados.map((rel) =>
								rel.slug ? (
									<a
										href={`/proyectos/${rel.slug}`}
										class="rounded-full border border-border bg-surface-2 px-4 py-2 font-mono text-xs text-primary transition hover:border-primary/60"
									>
										{rel.nombre}
									</a>
								) : (
									<a
										href="/#proyectos"
										class="rounded-full border border-border bg-surface-2 px-4 py-2 font-mono text-xs text-primary transition hover:border-primary/60"
									>
										{rel.nombre}
									</a>
								)
							)}
						</div>
					</div>
				)
			}
		</main>
	</body>
</html>
