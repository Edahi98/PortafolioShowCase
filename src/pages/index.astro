---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import SobreMi from '../components/SobreMi.astro';
import Proyectos from '../components/Proyectos.astro';
import Formacion from '../components/Formacion.astro';
import Habilidades from '../components/Habilidades.astro';
import Contacto from '../components/Contacto.astro';
---
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Edahi Yaxquin Avila Garcia · Portafolio</title>
		<meta
			name="description"
			content="Portafolio de Edahi Yaxquin Avila Garcia, desarrollador de software."
		/>
	</head>
	<body class="min-h-screen text-slate-200 antialiased">
		<Navbar />
		<main class="mx-auto flex max-w-5xl flex-col gap-24 px-6 py-20 sm:px-8">
			<Hero />
			<SobreMi />
			<Proyectos />
			<Formacion />
			<Habilidades />
			<Contacto />
		</main>
	</body>
</html>
