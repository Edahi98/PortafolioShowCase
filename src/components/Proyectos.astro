---
import { proyectos } from '../data/proyectos';
---
<section id="proyectos" class="flex scroll-mt-24 flex-col gap-6">
	<h2 class="text-sm font-mono tracking-widest text-secondary uppercase">Proyectos</h2>
	<div class="grid gap-6 sm:grid-cols-2">
		{
			proyectos.map((proyecto) =>
				proyecto.slug ? (
					<a
						href={`/proyectos/${proyecto.slug}`}
						class="glass-card group relative flex flex-col gap-3 overflow-hidden rounded-2xl p-6 transition hover:border-primary/60"
					>
						{proyecto.imagenes && proyecto.imagenes.length > 0 && (
							<div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
								<img
									src={proyecto.imagenes[0].src}
									alt=""
									class="h-full w-full object-cover"
								/>
								<div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/85 to-surface/50" />
							</div>
						)}
						<div class="relative flex flex-1 flex-col gap-3">
							<h3 class="text-lg font-semibold text-slate-100">{proyecto.nombre}</h3>
							<p class="text-sm text-slate-400">{proyecto.descripcion}</p>
							<div class="mt-auto flex flex-wrap gap-2 pt-2">
								{proyecto.stack.map((tech) => (
									<span class="rounded-full border border-border bg-surface-2 px-3 py-1 font-mono text-xs text-primary">
										{tech}
									</span>
								))}
							</div>
							<p class="font-mono text-xs text-secondary">Ver proyecto &rarr;</p>
						</div>
					</a>
				) : (
					<article class="glass-card flex flex-col gap-3 rounded-2xl p-6 transition hover:border-primary/60">
						<h3 class="text-lg font-semibold text-slate-100">{proyecto.nombre}</h3>
						<p class="text-sm text-slate-400">{proyecto.descripcion}</p>
						<div class="mt-auto flex flex-wrap gap-2 pt-2">
							{proyecto.stack.map((tech) => (
								<span class="rounded-full border border-border bg-surface-2 px-3 py-1 font-mono text-xs text-primary">
									{tech}
								</span>
							))}
						</div>
					</article>
				)
			)
		}
	</div>
</section>
