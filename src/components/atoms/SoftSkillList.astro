---
import FlipCard from '../react/FlipCard.tsx';

const habilidadesBlandas = [
	'Adaptabilidad',
	'Creatividad e innovación',
	'Cumplimiento de metas',
	'Trabajo en equipo',
	'Proactividad',
	'Iniciativa',
];
---
<div class="grid grid-cols-2 gap-3">
	{habilidadesBlandas.map((skill) => <FlipCard client:visible label={skill} />)}
</div>
