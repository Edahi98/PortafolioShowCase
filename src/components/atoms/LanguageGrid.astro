---
const lenguajes = [
	{ nombre: 'C#', icono: 'cs' },
	{ nombre: 'TypeScript', icono: 'ts' },
	{ nombre: 'JavaScript', icono: 'js' },
	{ nombre: 'Python', icono: 'py' },
	{ nombre: 'Rust', icono: 'rust' },
	{ nombre: 'Java', icono: 'java' },
];
---
<div class="grid grid-cols-3 gap-3">
	{
		lenguajes.map((lang) => (
			<div class="glass-card flex flex-col items-center gap-2 rounded-2xl p-4 transition hover:border-primary/60">
				<img
					src={`https://skillicons.dev/icons?i=${lang.icono}`}
					alt={lang.nombre}
					width="40"
					height="40"
					loading="lazy"
					class="h-10 w-10"
				/>
				<span class="font-mono text-xs text-slate-300">{lang.nombre}</span>
			</div>
		))
	}
</div>
