---
const herramientas = [
	{ nombre: 'Docker', icono: 'docker' },
	{ nombre: 'Deno', icono: 'deno' },
	{ nombre: 'N8N', icono: 'n8n' },
	{ nombre: 'Node.js', icono: 'nodejs' },
	{ nombre: 'Ollama', icono: 'ollama' },
	{ nombre: 'Git', icono: 'git' },
	{ nombre: 'GitHub', icono: 'github' },
];
---
<div class="grid grid-cols-3 gap-3">
	{
		herramientas.map((tool) => (
			<div class="glass-card flex flex-col items-center gap-2 rounded-2xl p-4 transition hover:border-primary/60">
				<img
					src={`https://skillicons.dev/icons?i=${tool.icono}`}
					alt={tool.nombre}
					width="40"
					height="40"
					loading="lazy"
					class="h-10 w-10"
				/>
				<span class="font-mono text-xs text-slate-300">{tool.nombre}</span>
			</div>
		))
	}
</div>
