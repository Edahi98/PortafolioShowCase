---
// skillicons.dev no incluye n8n ni ollama; para esos dos se usa simpleicons.org (en blanco).
const herramientas = [
	{ nombre: 'Docker', icono: 'docker', fuente: 'skillicons' },
	{ nombre: 'Deno', icono: 'deno', fuente: 'skillicons' },
	{ nombre: 'N8N', icono: 'n8n', fuente: 'simpleicons' },
	{ nombre: 'Node.js', icono: 'nodejs', fuente: 'skillicons' },
	{ nombre: 'Ollama', icono: 'ollama', fuente: 'simpleicons' },
	{ nombre: 'Git', icono: 'git', fuente: 'skillicons' },
	{ nombre: 'GitHub', icono: 'github', fuente: 'skillicons' },
];

function iconoUrl(tool: (typeof herramientas)[number]) {
	return tool.fuente === 'simpleicons'
		? `https://cdn.simpleicons.org/${tool.icono}/e2e8f0`
		: `https://skillicons.dev/icons?i=${tool.icono}`;
}
---
<div class="grid grid-cols-3 gap-3">
	{
		herramientas.map((tool) => (
			<div class="glass-card flex flex-col items-center gap-2 rounded-2xl p-4 transition hover:border-primary/60">
				<img
					src={iconoUrl(tool)}
					alt={tool.nombre}
					width="40"
					height="40"
					loading="lazy"
					class="h-10 w-10"
				/>
				<span class="font-mono text-xs text-slate-300">{tool.nombre}</span>
			</div>
		))
	}
</div>
