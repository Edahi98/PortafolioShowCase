---
import LanguageGrid from './atoms/LanguageGrid.astro';
import SoftSkillList from './atoms/SoftSkillList.astro';

const herramientas = ['Docker', 'Deno', 'N8N', 'Node.js', 'Ollama', 'Git / GitHub'];
---
<section id="habilidades" class="grid scroll-mt-24 gap-12 sm:grid-cols-3">
	<div class="flex flex-col gap-4">
		<h2 class="text-sm font-mono tracking-widest text-secondary uppercase">Lenguajes</h2>
		<LanguageGrid />
	</div>
	<div class="flex flex-col gap-4">
		<h2 class="text-sm font-mono tracking-widest text-secondary uppercase">Herramientas</h2>
		<div class="flex flex-wrap gap-2">
			{
				herramientas.map((tool) => (
					<span class="rounded-full border border-border bg-surface-2 px-3 py-1 font-mono text-xs text-slate-200">
						{tool}
					</span>
				))
			}
		</div>
	</div>
	<div class="flex flex-col gap-4">
		<h2 class="text-sm font-mono tracking-widest text-secondary uppercase">Habilidades blandas</h2>
		<SoftSkillList />
	</div>
</section>
